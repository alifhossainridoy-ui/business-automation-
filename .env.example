# Infra-level only. Per-business API keys (Facebook, WhatsApp, OpenRouter)
# are stored in the `businesses` table and entered through the dashboard —
# never put them here.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://redis:6379

DASHBOARD_PORT=3000
BACKEND_PORT=4000

# Meta App-level secrets (one Meta App, shared across every business's Page
# webhook subscription — not a per-business token, so it lives here rather
# than in the businesses table).
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# App ID paired with META_APP_SECRET above — needed to build the app access
# token the Health page uses to call Graph API's /debug_token.
META_APP_ID=

# Operator's own Telegram bot (e.g. @rupzone_ai_bot) — single alert channel
# for token expiry, WA quality drops, and backend errors, across every
# business. Not a per-business credential.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
